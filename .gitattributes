# 기본: Git이 텍스트 여부를 자동 판별하고, 저장소에는 LF로 정규화
* text=auto eol=lf

# 소스 파일은 LF로 통일
*.py   text eol=lf
*.html text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.md   text eol=lf

# Windows 배치 파일은 반드시 CRLF (CRLF 아니면 깨질 수 있음)
*.bat  text eol=crlf
*.cmd  text eol=crlf

# 바이너리/캐시: 줄바꿈 변환 금지
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
*.bin  binary
