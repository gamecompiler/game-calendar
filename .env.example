# 로컬 개발용 환경변수 예시. 실제 값을 채워 `.env`로 복사하세요.
# `.env`는 .gitignore에 등록되어 커밋되지 않습니다. 토큰을 코드에 절대 넣지 마세요.
#
# Vercel 배포 시에는 대시보드 > Environment Variables 에 동일 키로 등록합니다.

# 읽기 전용 Notion Integration 토큰 (멤버 DB / 공개 읽기용)
NOTION_READONLY_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 원스동 멤버 DB ID (미설정 시 코드 기본값 사용)
NOTION_MEMBERS_DB=3b756ebfd5754e1f8308310b50330806

# (선택) 팬 공개 읽기 허용 DB 화이트리스트 — 미설정 시 방송/문서 DB 기본값
# NOTION_PUBLIC_DB_IDS=1de66cc1f1b581c7a69cc00da09d16c4,20466cc1f1b58060b379eb16721bd1e4
